# Fichiers temporaires et dossiers à ignorer
__pycache__/
**/__pycache__/
logs/
.vscode/
.claude/
claudedocs/
backups/
context_storage/
rag_demo_index/

# Base de données vectorielles (données personnelles locales)
memory/vector_store/chroma_db/*
memory/vector_store/conversation_index.json
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm
*.faiss
*.index

# Modèles ML téléchargés (trop gros pour Git)
models/weights/
*.bin
*.safetensors
*.gguf
*.ggml

# Fichiers temporaires
temp/
*.tmp
*.cache

# Fichiers générés par l'IA
outputs/

# Entrainement et logs (sauf le readme.md)
models/training_runs/*
!models/training_runs/README.md

# Données RLHF
data/rlhf_feedback.db
data/rlhf_training_data.jsonl

# Agents customisés
data/custom_agents.json

# Bibliothèque de prompts / slash commands (les défauts sont seedés depuis le
# code via core/prompt_library._DEFAULT_TEMPLATES ; ce fichier = prompts perso)
data/prompt_templates.json

# Tâches planifiées (scheduler proactif — données locales par utilisateur)
data/scheduled_tasks.json
data/scheduler.lock

# Marqueur d'onboarding (état local : empêche le wizard de se réafficher)
data/.onboarding_done

# Fichiers de cache locaux
data/knowledge_base/
data/web_cache/
data/workspaces/
data/command_history*

# Fichier exécutable de Cloudflared (trop spécifique à l'environnement local)
tools/cloudflared.exe

# Backend de génération d'image auto-installé dans tools/ au 1er usage
# (téléchargé/extrait localement, ne doit jamais être committé)
tools/ComfyUI_windows_portable/
tools/ComfyUI_windows_portable_nvidia.7z
tools/7zr.exe